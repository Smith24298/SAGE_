// Copy to Firebase Console -> Firestore -> Rules (or firestore.rules if using CLI)
// These rules enforce: users can read/write only their own document (by uid).

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
